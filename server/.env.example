NODE_ENV=production

DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/vehicle_expense_manager
JWT_SECRET=change-this-to-a-long-random-secret-string
PORT=3001
CLIENT_URL=https://yourdomain.com

# Push notifications (run: node scripts/gen-vapid.js to generate these)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=admin@ritewater.in

# Email sender address (shown in From field)
SMTP_USER=you@yourdomain.com

# Zoho Mail REST API — used to send OTP emails
# Get these from https://api-console.zoho.in -> Self Client app
# Run: node scripts/get-zoho-token.js <auth-code>  to generate the refresh token
ZOHO_CLIENT_ID=your-self-client-id
ZOHO_CLIENT_SECRET=your-self-client-secret
ZOHO_REFRESH_TOKEN=your-refresh-token
